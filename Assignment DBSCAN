from sklearn.decomposition import PCA
from mpl_toolkits.mplot3d import Axes3D

pca = PCA(
    n_components=2
)

X_pca = pca.fit_transform(
    X_scaled
)

plt.figure(figsize=(10,6))

for cluster in set(labels):

    mask = labels == cluster

    if cluster == -1:

        plt.scatter(
            X_pca[mask,0],
            X_pca[mask,1],
            marker='x',
            color='black',
            label='Noise'
        )

    else:

        plt.scatter(
            X_pca[mask,0],
            X_pca[mask,1],
            label=f'Cluster {cluster}'
        )

plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("DBSCAN Clusters using PCA")
plt.legend()

plt.show()

pca3 = PCA(
    n_components=3
)

X_pca3 = pca3.fit_transform(
    X_scaled
)

fig = plt.figure(
    figsize=(10,8)
)

ax = fig.add_subplot(
    111,
    projection='3d'
)

ax.scatter(
    X_pca3[:,0],
    X_pca3[:,1],
    X_pca3[:,2],
    c=labels
)

plt.title(
    "3D PCA Visualization"
)

